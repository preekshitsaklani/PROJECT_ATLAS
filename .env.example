# ══════════════════════════════════════════════════════════════════
# ATLAS OSINT Intelligence System — Environment Configuration
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual API keys:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ─── LLM Models & Analytics ──────────────────────────────────────
# Primary: NVIDIA NIM (GLM-5 - Strategic Reasoning LLM)
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm5

# Fallback LLMs (optional)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OLLAMA_URL=http://localhost:11434

# ─── Database & Storage ──────────────────────────────────────────
# PostgreSQL (optional — system uses SQLite by default)
POSTGRES_USER=project_atlas
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=atlas_intel
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB (optional — for raw document caching)
MONGO_URI=mongodb://localhost:27017/atlas_cache
MONGO_DB_NAME=atlas_cache

# ─── Pinecone (Vector RAG Search) ────────────────────────────────
# Get your key at: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-east1-aws
PINECONE_INDEX_NAME=project-atlas
PINECONE_HOST_URL=https://your-index-host.svc.pinecone.io

# ─── Neo4j (Graph Database for Causal Reasoning) ─────────────────
# Download Neo4j Desktop: https://neo4j.com/download/
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_INSTANCE_NAME=ATLAS

# ─── Kafka / Event Streaming (optional) ──────────────────────────
KAFKA_BROKER_URL=localhost:9092
KAFKA_TOPIC_INTEL=atlas.osint.ingest

# ─── OSINT APIs ──────────────────────────────────────────────────

# Weather & Marine Routing
# Docs: https://openweathermap.org/api/one-call-3
# Limit: 2,000 calls/day (free tier), we use max 1,500/day
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Docs: https://docs.stormglass.io/#/
# Limit: 5 API calls/day (free tier)
STORMGLASS_API_KEY=your_stormglass_api_key_here

# Maritime AIS (Vessel Tracking)
# Docs: https://aisstream.io/documentation
AISSTREAM_IO_API_KEY=your_aisstream_api_key_here

# Docs: https://api.marinesia.com/redoc#tag/v2
# Limit: 1 request per 30 minutes
MARINESIA_API_KEY=your_marinesia_api_key_here

# Geopolitical, Sanctions & Conflict
# Docs: https://ucdpapi.pcr.uu.se/api/ (see project report for full docs)
# Limit: 5,000 requests/day (resets midnight UTC)
# Request token from: mert.yilmaz@pcr.uu.se
UCDP_API_TOKEN=your_ucdp_token_here

# Docs: https://acleddata.com/api-documentation/
# Get token at: https://developer.acleddata.com/
ACLED_ACCESS_TOKEN=your_acled_access_token_here
ACLED_REFRESH_TOKEN=your_acled_refresh_token_here

# Docs: https://newsapi.org/docs
# Limit: 100 requests/day (free tier)
NEWSAPI_KEY=your_newsapi_key_here

# Docs: https://newsdata.io/documentation
# Limit: 200 credits/day (10 articles per credit = 2,000 articles/day)
NEWSDATA_IO_KEY=your_newsdata_io_key_here

# ─── System Config ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_PORT=8000
FRONTEND_PORT=3000
SECRET_KEY=change-this-to-a-random-secret-string-in-production
